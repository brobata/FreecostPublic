<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Freecost.MainShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Freecost"
    Shell.FlyoutBehavior="Flyout"
    Title="Freecost">

    <TabBar>
        <ShellContent
            Title="Ingredients"
            ContentTemplate="{DataTemplate local:IngredientsPage}"
            Route="IngredientsPage" />
        <ShellContent
            Title="Recipes"
            ContentTemplate="{DataTemplate local:RecipesPage}"
            Route="RecipesPage" />
        <ShellContent
            Title="Entrees"
            ContentTemplate="{DataTemplate local:EntreesPage}"
            Route="EntreesPage" />
        <ShellContent
            Title="Locations"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Admin"
            ContentTemplate="{DataTemplate local:AdminPage}"
            Route="AdminPage"
            IsVisible="{Binding IsAdmin}" />
    </TabBar>

    <MenuItem Text="Change Location"
              Clicked="OnChangeLocationClicked" />
    <MenuItem Text="Logout"
                Clicked="OnLogoutClicked" />

</Shell>
