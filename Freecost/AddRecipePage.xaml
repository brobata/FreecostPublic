<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Freecost.AddRecipePage"
             Title="Add Recipe">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Frame Style="{StaticResource CardView}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Recipe Details" Style="{StaticResource SubHeadline}" />
                    <Entry x:Name="RecipeNameEntry" Placeholder="Recipe Name" />
                    <Grid ColumnDefinitions="*,*">
                        <Entry Grid.Column="0" x:Name="YieldEntry" Placeholder="Yield" Keyboard="Numeric" />
                        <Picker Grid.Column="1" x:Name="YieldUnitPicker" Title="Unit" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardView}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Allergens" Style="{StaticResource SubHeadline}" />
                    <FlexLayout x:Name="AllergensLayout" Wrap="Wrap" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardView}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ingredients" Style="{StaticResource SubHeadline}" />
                    <CollectionView x:Name="IngredientsCollection">
                    </CollectionView>
                    <HorizontalStackLayout Spacing="10">
                        <Picker x:Name="IngredientPicker" Title="Ingredient" HorizontalOptions="FillAndExpand" />
                        <Entry x:Name="QuantityEntry" Placeholder="Qty" Keyboard="Numeric" WidthRequest="70" />
                        <Picker x:Name="UnitPicker" Title="Unit" WidthRequest="100" />
                        <Button Text="Add" Clicked="OnAddIngredientClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Save Recipe" Clicked="OnSaveClicked" Style="{StaticResource EdgyButtonStyle}" HorizontalOptions="FillAndExpand" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>